let &t_SI = "\<Esc>]50;CursorShape=1\x7"
let &t_SR = "\<Esc>]50;CursorShape=2\x7"
let &t_EI = "\<Esc>]50;CursorShape=0\x7"
set ttimeout
set ttimeoutlen=1
set listchars=tab:>-,trail:~,extends:>,precedes:<,space:.
set ttyfast
let &t_TI = "\<Esc>[>4;2m"
let &t_TE = "\<Esc>[>4;m"

set nocompatible
syntax on
filetype plugin on
set termguicolors
packadd! comment
packadd! matchit
runtime! ftplugin/man.vim
if !has('clipboard')
	echoerr "This Vim is not compiled with clipboard support."
endif

if !has('lua')
	echoerr "This Vim is not compiled with Lua support."
endif
if !has('python3')
	let &pythonthreedll = split(system('ldconfig -p | grep libpython3'))[0]
	if !has('python3')
		echoerr "This Vim is not compiled with Python3 support."
	endif
endif

nnoremap Y y$
xnoremap Y y$

let s:file = expand('<sfile>')
function! s:setup()
	let s:nvim_config = trim(systemlist('nvim -l ' . fnamemodify(s:file, ':h') . '/.lua')[0])
	execute 'source ' . s:nvim_config . '/vimrc'
	execute 'set runtimepath+=' . s:nvim_config
endfunction
autocmd VimEnter * call s:setup()

set packpath+=/usr/share/vim/vimfiles
packadd! lazy/vim-dirvish
let g:dirvish_mode = ':sort ,^.*[\\/],'
if has('lua')
	packadd! lazy/dirvish-git.nvim
	" packadd! lazy/autosave.nvim
	packadd! lazy/copilot.vim
endif
